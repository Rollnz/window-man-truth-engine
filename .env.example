# ============================================================================
# WindowMan Truth Engine — Environment Template
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values.
# - VITE_* variables are bundled into the browser. NEVER put a service-role
#   key or any third-party private token in a VITE_* variable.
# - Edge Function secrets (bottom half) are server-only. Set them with
#   `supabase secrets set NAME=value` — they MUST NOT appear in .env.local
#   for the frontend.
# - Never commit a populated .env or .env.local.
# ============================================================================

# ─── Frontend (browser-safe, .env.local) ────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_APP_ENV=development
VITE_SITE_URL=http://localhost:8080

# Optional public IDs (safe to expose; verify before adding any)
# VITE_GTM_CONTAINER_ID=
# VITE_META_PIXEL_ID=
# VITE_GA4_MEASUREMENT_ID=


# ============================================================================
# Supabase Edge Function Secrets — DO NOT prefix with VITE_
# Set with:  supabase secrets set KEY=value
# Inspect:   supabase secrets list
# These names MUST NEVER appear in any file under src/ or public/.
# ============================================================================

# ── Supabase (server-only) ──────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ── Lovable AI Gateway (preferred for LLM calls in edge functions) ──────────
LOVABLE_API_KEY=

# ── Resend (transactional + auth emails) ────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO_EMAIL=

# ── Twilio Verify (SMS OTP) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_FROM_PHONE=

# ── Meta CAPI (server-side conversions) ─────────────────────────────────────
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# ── PhoneCall.bot (outbound dialer) ─────────────────────────────────────────
PHONECALLBOT_API_KEY=
PHONECALLBOT_WEBHOOK_SECRET=

# ── Nextdoor (future ad integration) ────────────────────────────────────────
NEXTDOOR_CLIENT_ID=
NEXTDOOR_CLIENT_SECRET=
NEXTDOOR_AD_ACCOUNT_ID=
NEXTDOOR_CONVERSION_ACCESS_TOKEN=

# ── App / internal ──────────────────────────────────────────────────────────
APP_BASE_URL=
EDGE_SHARED_SECRET=
LEAD_VERIFICATION_SECRET=
AUTH_HOOK_SECRET=
